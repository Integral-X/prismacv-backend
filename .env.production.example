# =============================================================================
# PrismaCV Backend — Production Environment Variables
# =============================================================================
# Copy to .env on your production server and fill in real values.
# Generate secrets with: openssl rand -base64 32
# =============================================================================

# Application
APP_NAME=PrismaCV
APP_VERSION=1.0.0
NODE_ENV=production
PORT=3210
API_PREFIX=api

# Frontend URL (used for OAuth callback redirects to the UI)
FRONTEND_URL=https://www.prismacv.com

# Database
DATABASE_URL="postgresql://prismacv:<password>@<host>:5432/prismacv"

# JWT Authentication (use unique random strings, ≥ 32 chars each)
JWT_SECRET=
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=
JWT_REFRESH_EXPIRES_IN=7d

# Encryption (used to encrypt OAuth tokens at rest; generate with: openssl rand -base64 32)
ENCRYPTION_KEY=

# Master Admin Credentials (seeded on first deploy)
MASTER_ADMIN_EMAIL=admin@prismacv.com
MASTER_ADMIN_PASSWORD=
MASTER_ADMIN_NAME=Master Admin

# Password Hashing
BCRYPT_ROUNDS=12

# Rate Limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# CORS
DISABLE_CORS=false
CORS_ORIGIN=https://www.prismacv.com

# SMTP Email Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=prismacv2025@gmail.com
SMTP_PASS=
SMTP_FROM_NAME=PrismaCV
SMTP_FROM_EMAIL=noreply@prismacv.com

# OTP Configuration
OTP_EXPIRY_MINUTES=10
OTP_MAX_ATTEMPTS_SIGNUP=5
OTP_MAX_ATTEMPTS_PASSWORD_RESET=3

# Logging
LOG_LEVEL=info

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://api.prismacv.com/api/v1/oauth/google/callback

# LinkedIn OAuth
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_CALLBACK_URL=https://api.prismacv.com/api/v1/oauth/linkedin/callback

# Unleash Feature Flags (optional — runs in mock mode if not configured)
# UNLEASH_URL=
# UNLEASH_API_TOKEN=
# UNLEASH_APP_NAME=prismacv-api
# UNLEASH_REFRESH_INTERVAL=15000
# UNLEASH_METRICS_INTERVAL=60000
