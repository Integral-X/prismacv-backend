generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String      @id @db.Uuid
  email         String      @unique
  password      String?
  name          String?
  role          UserRole  @default(REGULAR)
  isMasterAdmin Boolean   @default(false)
  refreshToken  String?
  emailVerified Boolean     @default(false)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  avatarUrl     String?
  provider      String?
  providerId    String?
  otps          Otp[]
  authTokens    AuthToken[]
  oauthAccessToken String?
  oauthRefreshToken String?
  oauthTokenExpiresAt DateTime?
  linkedinCvImports LinkedinCvImport[]
  cvs               Cv[]
  jobs              Job[]
  skillProgress     UserSkillProgress[]

  @@unique([provider, providerId])
  @@map("users")
}

model LinkedinCvImport {
  id             String   @id @db.Uuid
  userId         String   @db.Uuid
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider       String   @default("LINKEDIN")
  linkedinHandle String?
  linkedinUrl    String
  fetchedAt      DateTime @default(now())
  dataScope      Json
  warnings       Json?
  profile        Json
  experience     Json
  education      Json
  skills         Json
  certifications Json
  projects       Json
  publications   Json
  volunteer      Json
  honors         Json
  languages      Json
  courses        Json
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([userId, linkedinUrl])
  @@index([userId, fetchedAt])
  @@map("linkedin_cv_imports")
}

enum OAuthProvider {
  LINKEDIN
  GOOGLE
}

enum UserRole {
  REGULAR
  PLATFORM_ADMIN
}

enum OtpPurpose {
  SIGNUP_EMAIL_VERIFICATION
  PASSWORD_RESET
}

model Otp {
  id          String     @id @default(cuid())
  userId      String     @db.Uuid
  purpose     OtpPurpose
  otpHash     String
  attempts    Int        @default(0)
  maxAttempts Int        @default(3)
  expiresAt   DateTime
  usedAt      DateTime?
  createdAt   DateTime   @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, purpose])
  @@map("otp_tokens")
}

enum AuthTokenPurpose {
  PASSWORD_RESET
  EMAIL_VERIFICATION_LINK
  ACCOUNT_ACTIVATION
}

model AuthToken {
  id        String           @id @default(cuid())
  userId    String           @db.Uuid
  purpose   AuthTokenPurpose
  tokenHash String           @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, purpose])
  @@map("auth_tokens")
}

// ─── CV Models ───────────────────────────────────────────────────────────────

enum CvStatus {
  DRAFT
  PUBLISHED
}

enum SkillLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
  EXPERT
}

enum LanguageProficiency {
  BASIC
  INTERMEDIATE
  ADVANCED
  FLUENT
  NATIVE
}

model Cv {
  id         String   @id @db.Uuid
  userId     String   @db.Uuid
  title      String
  slug       String
  status     CvStatus @default(DRAFT)
  templateId String?
  isDefault  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  personalInfo   PersonalInfo?
  experiences    Experience[]
  education      Education[]
  skills         Skill[]
  certifications Certification[]
  projects       Project[]
  languages      Language[]
  customSections CustomSection[]
  share          CvShare?

  @@unique([userId, slug])
  @@index([userId, status])
  @@index([userId, updatedAt])
  @@map("cvs")
}

model PersonalInfo {
  id          String  @id @db.Uuid
  cvId        String  @unique @db.Uuid
  fullName    String?
  email       String?
  phone       String?
  location    String?
  website     String?
  linkedinUrl String?
  summary     String?
  avatarUrl   String?

  cv Cv @relation(fields: [cvId], references: [id], onDelete: Cascade)

  @@map("personal_info")
}

model Experience {
  id          String    @id @db.Uuid
  cvId        String    @db.Uuid
  company     String
  title       String
  location    String?
  startDate   DateTime
  endDate     DateTime?
  current     Boolean   @default(false)
  description String?
  sortOrder   Int       @default(0)

  cv Cv @relation(fields: [cvId], references: [id], onDelete: Cascade)

  @@index([cvId, sortOrder])
  @@map("experiences")
}

model Education {
  id          String    @id @db.Uuid
  cvId        String    @db.Uuid
  institution String
  degree      String
  field       String?
  startDate   DateTime
  endDate     DateTime?
  gpa         String?
  description String?
  sortOrder   Int       @default(0)

  cv Cv @relation(fields: [cvId], references: [id], onDelete: Cascade)

  @@index([cvId, sortOrder])
  @@map("education")
}

model Skill {
  id        String     @id @db.Uuid
  cvId      String     @db.Uuid
  name      String
  level     SkillLevel @default(INTERMEDIATE)
  category  String?
  sortOrder Int        @default(0)

  cv Cv @relation(fields: [cvId], references: [id], onDelete: Cascade)

  @@index([cvId, sortOrder])
  @@map("skills")
}

model Certification {
  id            String    @id @db.Uuid
  cvId          String    @db.Uuid
  name          String
  issuer        String?
  issueDate     DateTime?
  expiryDate    DateTime?
  credentialUrl String?
  sortOrder     Int       @default(0)

  cv Cv @relation(fields: [cvId], references: [id], onDelete: Cascade)

  @@index([cvId, sortOrder])
  @@map("certifications")
}

model Project {
  id          String    @id @db.Uuid
  cvId        String    @db.Uuid
  name        String
  description String?
  url         String?
  startDate   DateTime?
  endDate     DateTime?
  sortOrder   Int       @default(0)

  cv Cv @relation(fields: [cvId], references: [id], onDelete: Cascade)

  @@index([cvId, sortOrder])
  @@map("projects")
}

model Language {
  id          String              @id @db.Uuid
  cvId        String              @db.Uuid
  name        String
  proficiency LanguageProficiency @default(INTERMEDIATE)
  sortOrder   Int                 @default(0)

  cv Cv @relation(fields: [cvId], references: [id], onDelete: Cascade)

  @@index([cvId, sortOrder])
  @@map("languages")
}

model CustomSection {
  id        String @id @db.Uuid
  cvId      String @db.Uuid
  title     String
  entries   Json
  sortOrder Int    @default(0)

  cv Cv @relation(fields: [cvId], references: [id], onDelete: Cascade)

  @@index([cvId, sortOrder])
  @@map("custom_sections")
}

// ─── CV Sharing ──────────────────────────────────────────────────────────────

model CvShare {
  id            String    @id @db.Uuid
  cvId          String    @unique @db.Uuid
  shareSlug     String    @unique
  isPublic      Boolean   @default(true)
  viewCount     Int       @default(0)
  downloadCount Int       @default(0)
  lastViewedAt  DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  cv Cv @relation(fields: [cvId], references: [id], onDelete: Cascade)

  @@index([shareSlug])
  @@map("cv_shares")
}

// ─── Job Application Tracker ─────────────────────────────────────────────────

enum JobStatus {
  SAVED
  APPLIED
  INTERVIEW
  OFFER
  REJECTED
}

model Job {
  id          String    @id @db.Uuid
  userId      String    @db.Uuid
  title       String
  company     String
  url         String?
  location    String?
  isRemote    Boolean   @default(false)
  salaryMin   Int?
  salaryMax   Int?
  salaryCurrency String?
  status      JobStatus @default(SAVED)
  appliedAt   DateTime?
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobNotes  JobNote[]

  @@index([userId, status])
  @@index([userId, updatedAt])
  @@map("jobs")
}

model JobNote {
  id        String   @id @db.Uuid
  jobId     String   @db.Uuid
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  job Job @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId, createdAt])
  @@map("job_notes")
}

// ─── Skills & Career Development ─────────────────────────────────────────────

model SkillCategory {
  id          String @id @db.Uuid
  name        String @unique
  description String?
  icon        String?

  skills RoleSkillMap[]

  @@map("skill_categories")
}

model RoleSkillMap {
  id              String @id @db.Uuid
  role            String
  skillName       String
  categoryId      String @db.Uuid
  importance      Int    @default(3) // 1-5
  description     String?

  category SkillCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([role, skillName])
  @@index([role])
  @@map("role_skill_maps")
}

model UserSkillProgress {
  id         String   @id @db.Uuid
  userId     String   @db.Uuid
  skillName  String
  level      Int      @default(0) // 0-100
  status     String   @default("not_started") // not_started, learning, completed
  startedAt  DateTime?
  completedAt DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, skillName])
  @@index([userId])
  @@map("user_skill_progress")
}

model LearningResource {
  id          String @id @db.Uuid
  skillName   String
  title       String
  url         String
  platform    String // Coursera, Udemy, YouTube, etc.
  difficulty  String @default("beginner") // beginner, intermediate, advanced
  duration    String? // "2 hours", "4 weeks", etc.
  isFree      Boolean @default(false)
  createdAt   DateTime @default(now())

  @@index([skillName])
  @@map("learning_resources")
}

// ─── Interview Preparation ───────────────────────────────────────────────────

enum InterviewDifficulty {
  EASY
  MEDIUM
  HARD
}

model InterviewQuestion {
  id            String              @id @db.Uuid
  question      String
  sampleAnswer  String?
  category      String              // Behavioral, Technical, System Design, etc.
  role          String              // Software Engineer, Product Manager, etc.
  difficulty    InterviewDifficulty @default(MEDIUM)
  tips          String?
  createdAt     DateTime            @default(now())

  @@index([role, category])
  @@index([difficulty])
  @@map("interview_questions")
}
