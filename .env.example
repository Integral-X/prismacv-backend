# Application
APP_NAME=PrismaCV
APP_VERSION=1.0.0
NODE_ENV=development
PORT=3000
API_PREFIX=api
# Optional for Linux containers with custom Chromium path (PDF export)
CHROME_EXECUTABLE_PATH=/usr/bin/chromium-browser

# Frontend URL (used for OAuth callback redirects to the UI)
FRONTEND_URL=http://localhost:3001

# Database
DATABASE_URL="postgresql://prismacv:password@localhost:5432/prismacv_dev"
DATABASE_URL_TEST="postgresql://prismacv:password@localhost:5433/prismacv_test"

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your-super-secret-jwt-refresh-key-change-this-in-production
JWT_REFRESH_EXPIRES_IN=7d

# Encryption (used to encrypt OAuth tokens at rest; generate with: openssl rand -base64 32)
ENCRYPTION_KEY=your-encryption-key-at-least-32-characters

# Master Admin Credentials
MASTER_ADMIN_EMAIL=admin@example.com
MASTER_ADMIN_PASSWORD=change-this-admin-password
MASTER_ADMIN_NAME=Master Admin

# Password Hashing
BCRYPT_ROUNDS=12

# Rate Limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# CORS
DISABLE_CORS=true
CORS_ORIGIN=http://localhost:3001

# Unleash Feature Flags (optional — runs in mock mode if not configured)
UNLEASH_URL=https://unleash.prismacv.com/api/
UNLEASH_API_TOKEN=your-server-side-api-token-here
UNLEASH_APP_NAME=prismacv-api
UNLEASH_MOCK=false
UNLEASH_REFRESH_INTERVAL=15000
UNLEASH_METRICS_INTERVAL=60000

# SMTP Email Configuration (for OTP verification emails)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_SKIP_AUTH=false
SMTP_FROM_NAME=PrismaCV
SMTP_FROM_EMAIL=noreply@prismacv.com
SUPPORT_EMAIL=support@prismacv.com
MAILHOG_API_URL=http://localhost:8025
MAILHOG_E2E=false

# OTP Configuration
OTP_EXPIRY_MINUTES=10
OTP_MAX_ATTEMPTS_SIGNUP=5
OTP_MAX_ATTEMPTS_PASSWORD_RESET=3
RESET_TOKEN_EXPIRY_MINUTES=15

# Logging
LOG_LEVEL=info

# Sentry monitoring (optional)
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_RELEASE=1.0.0
SENTRY_TRACES_SAMPLE_RATE=0.05

# AI provider
AI_PROVIDER=builtin
AI_MODEL=gpt-4o-mini
AI_MAX_RETRIES=3
AI_TIMEOUT_MS=30000
AI_TEMPERATURE=0.2
AI_MONTHLY_CALL_LIMIT=200
AI_MONTHLY_CV_ANALYZE_LIMIT=120
AI_MONTHLY_CV_OPTIMIZE_LIMIT=80
AI_MONTHLY_GRAMMAR_CHECK_LIMIT=200
AI_MONTHLY_ATS_SCORE_LIMIT=120
AI_MONTHLY_COVER_LETTER_GENERATE_LIMIT=60
AI_ANALYSIS_CACHE_TTL_SECONDS=86400
OPENAI_API_KEY=

# Stripe billing
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRICE_PRO_MONTHLY=price_xxx
STRIPE_PRICE_PRO_YEARLY=price_xxx
STRIPE_PRICE_TEAM_MONTHLY=price_xxx
STRIPE_PRICE_TEAM_YEARLY=price_xxx
BILLING_PLAN_CACHE_TTL_SECONDS=60
BILLING_WEBHOOK_CACHE_LIMIT=500

# Background job queue (optional)
QUEUE_ENABLED=false
QUEUE_NAME=prismacv-jobs
REDIS_URL=redis://localhost:6379

# Google OAuth (optional — gracefully disabled if not configured)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:3000/api/v1/oauth/google/callback

# LinkedIn OAuth (optional — gracefully disabled if not configured)
LINKEDIN_CLIENT_ID=your_linkedin_client_id
LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret
LINKEDIN_CALLBACK_URL=http://localhost:3000/api/v1/oauth/linkedin/callback
LINKEDIN_API_TIMEOUT_MS=30000
